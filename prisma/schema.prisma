// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Movie {
  id              Int      @id @default(autoincrement())
  title           String
  posterPath      String
  backdropPath    String?
  voteAverage     Float
  overview        String
  runtime         Int
  director        String
  releaseDate     String
  
  // New rich content
  whyWatch        String?
  targetAudience  String?
  visualVibe      String?
  
  genres          Genre[]
  cast            CastMember[]
}

model Genre {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  movies Movie[]
}

model CastMember {
  id          Int     @id @default(autoincrement())
  name        String
  role        String
  profilePath String?
  movieId     Int
  movie       Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
}
